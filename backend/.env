PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ems_up

# AES-256 Chat & Voter Record Encryption (must be exactly 32 chars)
CHAT_SECRET_KEY=ems_pro_2026_chat_AES256key_32b!

# Redis — single node (dev). For 6-node cluster set REDIS_NODES instead:
# REDIS_NODES=127.0.0.1:7000,127.0.0.1:7001,127.0.0.1:7002,127.0.0.1:7003,127.0.0.1:7004,127.0.0.1:7005
REDIS_URL=redis://127.0.0.1:6379

# Elasticsearch — single node (dev)
# For cluster: ELASTIC_NODES=http://es1:9200,http://es2:9200,http://es3:9200
ELASTIC_URL=http://localhost:9200
# ELASTIC_API_KEY=<base64-api-key>     # production auth
# ELASTIC_USERNAME=elastic
# ELASTIC_PASSWORD=changeme